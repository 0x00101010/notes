---
import '../styles/global.css';

interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;

// Active theme. Change to one of:
//   light | dark | github | solarized-light | solarized-dark |
//   nord | catppuccin | tokyo-night
const ACTIVE_THEME = 'catppuccin';
---

<html lang="en" data-theme={ACTIVE_THEME}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
</head>
<body>
  <div class="page">
    <a href={import.meta.env.BASE_URL}
       style="display:inline-block;margin-bottom:1rem;font-size:0.82rem;color:var(--muted);text-decoration:none;font-family:system-ui,sans-serif;transition:color 0.15s;"
       onmouseover="this.style.color='var(--accent)'"
       onmouseout="this.style.color='var(--muted)'">&larr; Home</a>
    <h1>{title}</h1>
    {subtitle && <p class="subtitle">{subtitle}</p>}
    <slot />
  </div>
</body>
</html>
