---
import '../styles/global.css';

// Active theme. Change to one of:
//   light | dark | github | solarized-light | solarized-dark |
//   nord | catppuccin | tokyo-night
const ACTIVE_THEME = 'catppuccin';
---

<html lang="en" data-theme={ACTIVE_THEME}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Native 200ms Blocks</title>
</head>
<body>
  <div class="page" style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh;">
    <h1 style="text-align:center;margin-bottom:0.5em;">Native 200ms Blocks</h1>
    <p style="text-align:center;color:var(--muted);font-family:system-ui,sans-serif;max-width:42ch;margin-bottom:2rem;">
      Engineering plans for moving Base from 2-second blocks (with Flashblocks preconfirmations) to native 200ms.
    </p>
    <a href={`${import.meta.env.BASE_URL}plan`}
       style="font-family:system-ui,sans-serif;font-size:0.95rem;font-weight:500;color:var(--accent);padding:10px 20px;border:1px solid var(--accent);border-radius:8px;text-decoration:none;transition:background 0.15s;"
       onmouseover="this.style.background='color-mix(in srgb, var(--accent) 12%, transparent)'"
       onmouseout="this.style.background='transparent'">
      Read the plan &rarr;
    </a>
  </div>
</body>
</html>
